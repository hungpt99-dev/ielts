{
  "name": "@ielts/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:debug": "vite --host 127.0.0.1 --port 5173 --strictPort --debug",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts --watch",
    "ai": "VITEST_MAX_WORKERS=2 vitest run --config vitest.config.ts --passWithNoTests --reporter verbose",
    "clean": "rm -rf dist node_modules/.tmp"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@ielts/ai": "workspace:*",
    "@ielts/ai-tutor": "workspace:*",
    "@ielts/content": "workspace:*",
    "@ielts/exercises": "workspace:*",
    "@ielts/learning-engine": "workspace:*",
    "@ielts/settings": "workspace:*",
    "@ielts/storage": "workspace:*",
    "@ielts/theme": "workspace:*",
    "@ielts/ui": "workspace:*",
    "@ielts/utils": "workspace:*",
    "dexie": "^4.4.4",
    "idb": "^8.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.24.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.3",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.1.1"
  }
}
