+    expect(result).not.toBeNull()
+    expect(result!.skill).toBe('Grammar')
+  })
+
+  it('returns first content template as fallback when title matches nothing', () => {
+    const result = getContentByTitle('Create a daily study plan')
+    expect(result).toBeNull()
+    const all = getAllContentTemplates()
+    expect(all.length).toBeGreaterThan(0)
+  })
