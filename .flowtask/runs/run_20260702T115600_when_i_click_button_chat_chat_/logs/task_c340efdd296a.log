diff --git a/apps/web/src/services/ai/AIService.ts b/apps/web/src/services/ai/AIService.ts
index deeec73..7bb1a47 100644
--- a/apps/web/src/services/ai/AIService.ts
+++ b/apps/web/src/services/ai/AIService.ts
@@ -91,12 +91,20 @@ export function extractJSON(text: string): unknown {
   const jsonStart = text.indexOf('{')
   const jsonEnd = text.lastIndexOf('}')
