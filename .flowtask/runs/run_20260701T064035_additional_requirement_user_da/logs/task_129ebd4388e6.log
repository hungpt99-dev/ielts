+async importMergeAll(data: AppExportData): Promise<ImportSummary> {
+  const summary: ImportSummary = { added: 0, updated: 0, skipped: 0, failed: 0, errors: [] }
+  const db = getDb()
+  await db.transaction('rw', TABLE_NAMES, async () => {
+    for (const key of TABLE_NAMES) {
+      const items = data[key]
+      if (!items || items.length === 0) continue
+      for (const item of items) {
+        try {
+          validate(key, item)
+          const itemRecord = item as Record<string, unknown>
+          const existing = itemRecord.id
+            ? await db.table(key).get(itemRecord.id as string)
+            : undefined
+          if (existing) {
+            await db.table(key).put(item as never)
