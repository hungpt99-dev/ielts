+// Public API Imported Content
+async addPublicApiContent(item: Omit<PublicApiImportedContent, 'id' | 'importedAt'> & { id?: string; importedAt?: string }): Promise<PublicApiImportedContent> {
+  return safeDb(async () => {
+    const now = new Date().toISOString()
+    const entry: PublicApiImportedContent = {
+      ...item as PublicApiImportedContent,
+      id: item.id || crypto.randomUUID(),
+      tags: item.tags || [],
+      importedAt: item.importedAt || now,
+    }
+    validate('publicApiContent', entry)
+    const db = getDb()
+    await db.publicApiContent.put(entry)
+    return entry
+  })
+},
+
