import json
with open('/Users/phamthanhhung/Desktop/MyProject/IELTS/dist/manifest.webmanifest') as f:
    m = json.load(f)

# Comprehensive web manifest validation
errors = []
warnings = []

# Required fields per W3C规范
if not m.get('name'): errors.append('name is required')
if not m.get('short_name'): errors.append('short_name is required')
if not m.get('start_url'): errors.append('start_url is required')
if not m.get('display'): errors.append('display is required')
if m.get('display') not in ('fullscreen','standalone','minimal-ui','browser'):
    errors.append(f'invalid display: {m.get(\"display\")}')

if not m.get('icons'): errors.append('icons is required')
else:
    for i, icon in enumerate(m['icons']):
        if not icon.get('src'): errors.append(f'icons[{i}] missing src')
        if not icon.get('sizes'): errors.append(f'icons[{i}] missing sizes')
        if not icon.get('type'): errors.append(f'icons[{i}] missing type')

# Recommended but optional
if not m.get('description'): warnings.append('description recommended')
if not m.get('background_color'): warnings.append('background_color recommended')
if not m.get('theme_color'): warnings.append('theme_color recommended')

if errors:
    print('ERRORS:')
    for e in errors: print(f'  - {e}')
else:
    print('No errors')

if warnings:
