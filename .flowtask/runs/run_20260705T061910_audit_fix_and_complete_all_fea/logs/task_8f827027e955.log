const { JSDOM } = require('jsdom');
const dom = new JSDOM('<!DOCTYPE html><html><body></body></html>');
const { window } = dom;
const { indexedDB } = window;
console.log('indexedDB available:', typeof indexedDB);
if (indexedDB) {
  const req = indexedDB.open('test', 1);
  req.onupgradeneeded = () => {
    const db = req.result;
    db.createObjectStore('items', { keyPath: 'id' });
  };
  req.onsuccess = () => {
    const db = req.result;
    console.log('DB opened successfully');
    const tx = db.transaction('items', 'readwrite');
    const store = tx.objectStore('items');
    store.put({ id: '1', name: 'test' });
    tx.oncomplete = () => {
      console.log('Data written');
      const tx2 = db.transaction('items', 'readonly');
      const store2 = tx2.objectStore('items');
      const getReq = store2.get('1');
      getReq.onsuccess = () => {
        console.log('Data read:', getReq.result);
        db.close();
        indexedDB.deleteDatabase('test');
      };
    };
  };
  req.onerror = () => console.log('Error:', req.error);
}
